<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
  <!-- Checked/Selected state -->
  <item android:state_checked="true">
    <shape android:shape="rectangle">
      <corners android:radius="12dp"/>
      <solid android:color="@color/tool_selected_background"/>
      <stroke
        android:width="3dp"
        android:color="@color/tool_selected_border"/>
    </shape>
  </item>

  <!-- Default/Unselected state -->
  <item>
    <shape android:shape="rectangle">
      <corners android:radius="12dp"/>
      <solid android:color="@color/tool_unselected_background"/>
      <stroke
        android:width="1dp"
        android:color="@color/tool_unselected_border"/>
    </shape>
  </item>
</selector>
