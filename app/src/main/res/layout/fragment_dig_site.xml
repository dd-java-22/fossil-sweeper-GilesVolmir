<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  xmlns:app="http://schemas.android.com/apk/res-auto">

  <HorizontalScrollView
    android:id="@+id/dig_tool_bar_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:scrollbars="none"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <RadioGroup
      android:id="@+id/dig_tool_bar"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:layout_gravity="center"
      />
<!--      app:chipSpacingHorizontal="@dimen/dig_toolbar_spacing"-->
<!--      android:padding="@dimen/half_static_spacing"-->

  </HorizontalScrollView>


  <edu.cnm.deepdive.fossilsweeper.view.DigSiteView
    android:id="@+id/dig_site"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="@dimen/half_static_spacing"
    app:layout_constraintTop_toBottomOf="@id/dig_tool_bar_container"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
