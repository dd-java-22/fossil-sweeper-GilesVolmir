<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  >

  <ImageView
    android:id="@+id/fossil_image"
    android:layout_width="0dp"
    android:layout_height="0dp"
    app:layout_constraintWidth_percent="0.85"
    app:layout_constraintDimensionRatio="H,1.0"
    android:src="@drawable/main_logo"
    android:layout_margin="@dimen/half_static_spacing"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    />

  <TextView
    android:id="@+id/fossil_name"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="@string/fossil_view_dialog_title"
    android:textSize="@dimen/title_text_size"
    android:textStyle="bold"
    android:layout_margin="@dimen/half_static_spacing"
    app:layout_constraintTop_toBottomOf="@id/fossil_image"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    />

  <TextView
    android:id="@+id/fossil_info_table"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/half_static_spacing"
    android:textSize="@dimen/stats_text_size"
    app:layout_constraintBottom_toTopOf="@+id/fossil_info_table2"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@id/fossil_name"
    android:text="Sample Fossil Info"/>

  <TextView
    android:id="@+id/fossil_info_table2"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/half_static_spacing"
    android:textSize="@dimen/stats_text_size"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/fossil_info_table"
    app:layout_constraintBottom_toTopOf="@id/fossil_info_table3"
    android:text="Sample Fossil Info"
    />

  <TextView
    android:id="@+id/fossil_info_table3"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/half_static_spacing"
    android:textSize="@dimen/stats_text_size"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toBottomOf="@+id/fossil_info_table2"
    android:text="Sample Fossil Info"
    />

</androidx.constraintlayout.widget.ConstraintLayout>