<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
  xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  tools:context=".controller.MainFragment"
  >

  <com.google.android.material.appbar.AppBarLayout
    android:id="@+id/app_bar_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:elevation="4dp"
    >

    <com.google.android.material.appbar.MaterialToolbar
      android:id="@+id/toolbar"
      android:layout_width="match_parent"
      android:layout_height="?attr/actionBarSize"
      app:title="@string/app_name"
      />

  </com.google.android.material.appbar.AppBarLayout>

  <androidx.constraintlayout.widget.ConstraintLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    >

    <ImageView
      android:id="@+id/main_menu_logo"
    android:layout_width="0dp"
    app:layout_constraintWidth_percent="0.6"
    android:layout_height="0dp"
    app:layout_constraintDimensionRatio="1:1"
    android:src="@drawable/main_logo"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintBottom_toTopOf="@id/play_game_button"
    app:layout_constraintVertical_chainStyle="packed"
    android:layout_margin="@dimen/half_static_spacing"
    />

  <Button
    android:id="@+id/play_game_button"
    android:text="@string/play_game_button_text"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toBottomOf="@id/main_menu_logo"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintBottom_toTopOf="@id/fossil_gallery_button"
    app:layout_constraintVertical_chainStyle="packed"
    android:layout_margin="@dimen/half_static_spacing"
    />

  <Button
    android:id="@+id/fossil_gallery_button"
    android:text="@string/fossil_gallery_button_text"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toBottomOf="@id/play_game_button"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintBottom_toTopOf="@id/settings_button"
    app:layout_constraintVertical_chainStyle="packed"
    android:layout_margin="@dimen/half_static_spacing"
    />

  <Button
    android:id="@+id/settings_button"
    android:text="@string/settings_button_text"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toBottomOf="@id/fossil_gallery_button"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintBottom_toTopOf="@id/logout_button"
    app:layout_constraintVertical_chainStyle="packed"
    android:layout_margin="@dimen/half_static_spacing"
    android:layout_marginBottom="@dimen/half_static_spacing"
    />

  <Button
    android:id="@+id/logout_button"
    android:text="@string/logout_button_text"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    app:layout_constraintTop_toBottomOf="@id/settings_button"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintVertical_chainStyle="packed"
    android:layout_margin="@dimen/half_static_spacing"
    android:layout_marginBottom="@dimen/half_static_spacing"
    />

  </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
